---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { Image } from 'astro:assets';
import coverImg from '../../assets/Kia-Stock-Locator/cover.jpg';
import benchPorsche from '../../assets/Kia-Stock-Locator/stock-locator-porsche.png';
import benchRivian from '../../assets/Kia-Stock-Locator/stock-locator-rivian.png';
import benchTesla from '../../assets/Kia-Stock-Locator/stock-locator-tesla.jpg';
import benchRenault from '../../assets/Kia-Stock-Locator/stock-locator-renault.png';
import wireframeImg from '../../assets/Kia-Stock-Locator/wireframe.jpg';
import componentsImg from '../../assets/Kia-Stock-Locator/components.png';
import homeDesktop from '../../assets/Kia-Stock-Locator/desktop/old-stock-locator-home.jpg';
import resultsDesktop from '../../assets/Kia-Stock-Locator/desktop/old-stock-locator-results.jpg';
import detailsDesktop from '../../assets/Kia-Stock-Locator/desktop/old-stock-locator-details.jpg';
import newHome from '../../assets/Kia-Stock-Locator/desktop/new-stock-locator-home.jpg';
import newHomeType from '../../assets/Kia-Stock-Locator/desktop/new-stock-locator-home-type.jpg';
import newResults from '../../assets/Kia-Stock-Locator/desktop/new-stock-locator-results.jpg';
import newFilters from '../../assets/Kia-Stock-Locator/desktop/new-stock-locator-filters.jpg';
import newDetails from '../../assets/Kia-Stock-Locator/desktop/new-stock-locator-details.jpg';
import homeModelsMobile from '../../assets/Kia-Stock-Locator/Home-Models-Mobile-scaled.jpg';
import homeTypeMobile from '../../assets/Kia-Stock-Locator/Home-Type-Mobile-scaled.jpg';
import resultsMobile from '../../assets/Kia-Stock-Locator/Results-Mobile-scaled.jpg';
import filtersMobile from '../../assets/Kia-Stock-Locator/Filters-Mobile-scaled.jpg';
import detailsPreownedMobile from '../../assets/Kia-Stock-Locator/Details-Pre-owned-Mobile-scaled.jpg';
import detailsImagesMobile from '../../assets/Kia-Stock-Locator/Details-Images-Mobile-scaled.jpg';
import dealerFormMobile from '../../assets/Kia-Stock-Locator/Dealer-Form-Mobile-scaled.jpg';
import dealerPhoneMobile from '../../assets/Kia-Stock-Locator/Dealer-Phone-and-Map-Mobile-scaled.jpg';
import laptopImg from '../../assets/Kia-Stock-Locator/laptop.jpg';
import personUsingApp from '../../assets/Kia-Stock-Locator/person-using-app.jpg';
import ProjectFooter from '../../components/ProjectFooter.astro';
import Icon from '../../components/Icon.astro';
import ComponentsImage from '../../components/ComponentsImage.astro';
import '../../styles/global.css';
---

<Layout>
  <main>

    <Nav backHref="/" />

    <!-- Hero -->
    <section class="flex flex-col pt-24 pb-16" id="hero">
      <div class="max-w-7xl mx-auto w-full px-8">
        <h1 class="text-[clamp(2.5rem,7vw,6rem)] font-semibold leading-[1.05] tracking-tight mb-12 break-words" id="hero-title">
          Kia Stock Locator
        </h1>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Role</p>
            <p class="text-lg font-medium">Lead Designer</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Company</p>
            <p class="text-lg font-medium">Kia</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Year</p>
            <p class="text-lg font-medium">2023</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Type</p>
            <p class="text-lg font-medium">Web responsive</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cover image -->
    <section class="mb-24 overflow-hidden md:overflow-visible">
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={coverImg} alt="Kia Stock Locator cover" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" id="cover-img" />
      </div>
    </section>

    <!-- Opportunity -->
    <section class="mb-20 section-block" id="opportunity">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Opportunity</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">
              This project came off the back of my work on Kia's car configurator, a previous engagement that went so well Kia came back with a new challenge.
            </p>
            <p class="text-lg leading-relaxed opacity-80">
              During that period, a global chip shortage was causing significant delays in car delivery timelines, pushing customers to wait months for their configured vehicle.
            </p>
          </div>
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">
              The idea emerged: what if customers could find a similar or identical vehicle already in stock at a nearby dealer?
            </p>
            <p class="text-lg leading-relaxed opacity-80">
              Facing an increasingly competitive automotive landscape online, Kia decided to invest in improving their Stock Locator experience, helping customers find the right car now, rather than wait.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Goals -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Goals</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-xl font-semibold leading-relaxed opacity-80 mb-4">Immediate wins</p>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
              <li>Improve overall design, give vehicle images more relevance and restructure information display</li>
              <li>Rethink filters, avoid technical terminology</li>
              <li>Enable easy customer-dealer connections</li>
            </ul>
          </div>
          <div>
            <p class="text-xl font-semibold leading-relaxed opacity-80 mb-4">Future offerings and features</p>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
              <li>Pre-owned vehicles</li>
              <li>Kia Flex (leasing)</li>
              <li>Favorite cars functionality</li>
              <li>Vehicle comparison tools</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Timeline</h2>
        <p class="text-xl font-semibold leading-relaxed opacity-80 mb-4">4 weeks</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
              <li>Discovery<span class="opacity-60"> ⋅ 1 week</span></li>
                <ul class="list-disc list-outside pl-5 mt-1 mb-2">
                  <li>Competitive benchmark</li>
                  <li>Stakeholder workshops</li>
                  <li>Data analysis</li>
                </ul>
              <li>Solution design<span class="opacity-60"> ⋅ 2 weeks</span></li>
                <ul class="list-disc list-outside pl-5 mt-1">
                  <li>User flows</li>
                  <li>Wireframes</li>
                  <li>High-fidelity designs</li>
                  <li>Prototypes</li>
                </ul>
            </ul>
          </div>
          <div>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
              <li>Usability testing<span class="opacity-60"> ⋅ 1 week</span></li>
                <ul class="list-disc list-outside pl-5 mt-1">
                  <li>Scenario and tasks setup</li>
                  <li>Tests</li>
                  <li>Findings analysis</li>
                  <li>Documentation and reporting</li>
                </ul>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Laptop image -->
    <section class="mb-24 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={laptopImg} alt="Kia Stock Locator on laptop" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" />
      </div>
    </section>

    <!-- Team -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Team</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <p class="text-lg leading-relaxed opacity-80">
            The design team consisted of myself as Lead Designer and another product designer. I assigned the tasks and deliverables based on our strengths and interests, while ensuring we both contributed to all aspects of the project.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
             We also got support from a UX researcher for the usability testing phase. I collaborated closely with Kia's CX Manager, Italian market managers (pilot market), and Kia's Product team.
          </p>
        </div>
      </div>
    </section>

    <!-- My Role -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">My role as Lead Designer</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 mx-auto gap-8">
          <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
            <li>Design & research strategy</li>
            <li>Process & timeline management</li>
            <li>Task assignment & team coordination</li>
            <li>Competitive benchmark & data analysis</li>
            <li>Stakeholder workshops facilitation</li>
            <li>User flows, wireframes & prototypes</li>
            <li>High-fidelity designs</li>
          </ul>
          <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
            <li>Usability testing coordination with UX researcher</li>
            <li>Findings analysis & reporting</li>
            <li>Stakeholder alignment with:
              <ul class="list-disc list-outside pl-5 ml-1 mt-1">
                <li>Kia's CX Manager</li>
                <li>Italian market managers</li>
                <li>Kia's Product team</li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Competitive Benchmark -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Competitive benchmark</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            Conducted a thorough analysis of the competitive landscape, studying how leading automotive brands approach their stock locator and vehicle discovery experiences.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            Brands analyzed: Porsche, Volkswagen, Tesla, Rivian and Renault.
          </p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto md:px-8 overflow-hidden md:overflow-visible">
        <div class="relative" id="bench-img-container">
          <Image src={benchPorsche} alt="Porsche stock locator" id="bench-img-1" class="w-[810px] max-w-none md:w-full md:rounded-2xl object-cover" />
          <Image src={benchRivian} alt="Rivian stock locator" id="bench-img-2" class="absolute inset-0 w-[810px] max-w-none md:w-full md:rounded-2xl object-cover opacity-0" />
          <Image src={benchTesla} alt="Tesla stock locator" id="bench-img-3" class="absolute inset-0 w-[810px] max-w-none md:w-full md:rounded-2xl object-cover opacity-0" />
          <Image src={benchRenault} alt="Renault stock locator" id="bench-img-4" class="absolute inset-0 w-[810px] max-w-none md:w-full md:rounded-2xl object-cover opacity-0" />
        </div>
        <p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center" id="bench-caption">Porsche stock locator</p>
      </div>
    </section>

    <!-- Stakeholder workshops -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Stakeholder workshops</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <p class="text-lg leading-relaxed opacity-80">
            I facilitated workshops with Kia's stakeholders to align on user needs, business priorities, and key pain points before moving into solution design.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            These sessions helped surface insights from the frontline, dealership feedback, customer behaviour patterns, and market-specific constraints that shaped our design direction.
          </p>
        </div>
      </div>
    </section>

    <!-- Current website -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8 mb-16">
        <h2 class="text-section-heading mb-6">Current website</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <p class="text-lg leading-relaxed opacity-80">
            Before designing the new experience, the existing stock locator was audited to understand where users were struggling and why drop-off rates were high.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            The audit revealed recurring patterns: an overwhelming number of filter options, dense information that was hard to scan, and a multi-step flow that required too much effort before users could see relevant results.
          </p>
        </div>
      </div>
      <div class="flex flex-col gap-12">
          <div>
            <div class="max-w-5xl mx-auto px-8 mb-4">
              <p class="text-xl font-semibold leading-relaxed mb-4">Home</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <p class="text-lg leading-relaxed opacity-80">A large marketing banner dominated the top of the page, pushing the search experience below the fold.</p>
                <p class="text-lg leading-relaxed opacity-80">Model filters, body types, and categories were all presented at once, making it unclear where users should begin.</p>
              </div>
            </div>
            <div class="max-w-5xl mx-auto md:px-8">
              <div class="mb-3 px-8 md:px-0">
                <span class="inline-flex items-center gap-x-1.5 rounded-full px-3 py-1 text-sm font-medium text-[var(--text)] ring-1 ring-inset ring-[var(--border)]">
                  <Icon name="Info" size={14} />
                  <span class="hidden md:inline">Click the image to reveal the new design</span>
                  <span class="md:hidden">Tap the image to reveal the new design</span>
                </span>
              </div>
              <div class="image-toggle relative cursor-pointer select-none" data-state="before">
                <Image src={homeDesktop} alt="Current website — Home" class="w-full md:rounded-2xl toggle-before" />
                <Image src={newHome} alt="New design — Home" class="w-full md:rounded-2xl toggle-after hidden" />
                <div class="toggle-badge absolute pointer-events-none opacity-0 transition-opacity duration-300 rounded-full bg-black/65 text-white text-sm font-medium tracking-wide px-4 py-1 backdrop-blur-sm">Before</div>
              </div>
            </div>
          </div>
          <div>
            <div class="max-w-5xl mx-auto px-8 mb-4">
              <p class="text-xl font-semibold leading-relaxed mb-4">Results</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <p class="text-lg leading-relaxed opacity-80">The results page was dense and lacked visual hierarchy, making it hard to compare vehicles or quickly spot the most relevant details.</p>
                <p class="text-lg leading-relaxed opacity-80">Car images were small and thumbnail-like, failing to give users a proper sense of the vehicle.</p>
              </div>
            </div>
            <div class="max-w-5xl mx-auto md:px-8">
              <div class="mb-3 px-8 md:px-0">
                <span class="inline-flex items-center gap-x-1.5 rounded-full px-3 py-1 text-sm font-medium text-[var(--text)] ring-1 ring-inset ring-[var(--border)]">
                  <Icon name="Info" size={14} />
                  <span class="hidden md:inline">Click the image to reveal the new design</span>
                  <span class="md:hidden">Tap the image to reveal the new design</span>
                </span>
              </div>
              <div class="image-toggle relative cursor-pointer select-none" data-state="before">
                <Image src={resultsDesktop} alt="Current website — Results" class="w-full md:rounded-2xl toggle-before" />
                <Image src={newResults} alt="New design — Results" class="w-full md:rounded-2xl toggle-after hidden" />
                <div class="toggle-badge absolute pointer-events-none opacity-0 transition-opacity duration-300 rounded-full bg-black/65 text-white text-sm font-medium tracking-wide px-4 py-1 backdrop-blur-sm">Before</div>
              </div>
            </div>
          </div>
          <div>
            <div class="max-w-5xl mx-auto px-8 mb-4">
              <p class="text-xl font-semibold leading-relaxed mb-4">Vehicle details</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <p class="text-lg leading-relaxed opacity-80">Key specs and calls to action were buried under excessive content with no clear structure.</p>
                <p class="text-lg leading-relaxed opacity-80">Users had to scroll through most of the page before reaching the actions they actually needed.</p>
              </div>
            </div>
            <div class="max-w-5xl mx-auto md:px-8">
              <div class="mb-3 px-8 md:px-0">
                <span class="inline-flex items-center gap-x-1.5 rounded-full px-3 py-1 text-sm font-medium text-[var(--text)] ring-1 ring-inset ring-[var(--border)]">
                  <Icon name="Info" size={14} />
                  <span class="hidden md:inline">Click the image to reveal the new design</span>
                  <span class="md:hidden">Tap the image to reveal the new design</span>
                </span>
              </div>
              <div class="image-toggle relative cursor-pointer select-none" data-state="before">
                <Image src={detailsDesktop} alt="Current website — Details" class="w-full md:rounded-2xl toggle-before" />
                <Image src={newDetails} alt="New design — Details" class="w-full md:rounded-2xl toggle-after hidden" />
                <div class="toggle-badge absolute pointer-events-none opacity-0 transition-opacity duration-300 rounded-full bg-black/65 text-white text-sm font-medium tracking-wide px-4 py-1 backdrop-blur-sm">Before</div>
              </div>
            </div>
          </div>
        </div>
    </section>

    <!-- Wireframes -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8 mb-8">
        <h2 class="text-section-heading mb-6">Wireframes</h2>
        <p class="text-lg leading-relaxed opacity-80">
          Using FigJam, we explored the information architecture and layout before moving into high-fidelity designs.
        </p>
      </div>
      <div class="max-w-5xl mx-auto md:px-8">
        <Image src={wireframeImg} alt="Wireframes" class="w-full mx-auto block md:rounded-2xl" />
      </div>
    </section>

    <!-- Components -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Components</h2>
        <p class="text-lg leading-relaxed opacity-80 mb-8">
          We designed distinct card types to support new vehicles, pre-owned, and Kia Flex leasing offerings — each visually differentiated and scannable.
        </p>
      </div>
      <ComponentsImage src={componentsImg} alt="Card components" />
    </section>

    <!-- Designs — Desktop -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8 mb-8">
        <h2 class="text-section-heading mb-6">High fidelity designs</h2>
        <p class="text-xl font-semibold leading-relaxed opacity-80">Desktop</p>
      </div>
      <div class="max-w-5xl mx-auto flex flex-col gap-8 md:px-8">
        <div><Image src={newHome} alt="Home desktop" class="w-full md:rounded-2xl" /><p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center">Home</p></div>
        <div><Image src={newHomeType} alt="Home ⋅ Type desktop" class="w-full md:rounded-2xl" /><p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center">Home ⋅ Type</p></div>
        <div><Image src={newResults} alt="Results desktop" class="w-full md:rounded-2xl" /><p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center">Results</p></div>
        <div><Image src={newFilters} alt="Filters desktop" class="w-full md:rounded-2xl" /><p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center">Filters</p></div>
        <div><Image src={newDetails} alt="Vehicle details desktop" class="w-full md:rounded-2xl" /><p class="text-sm opacity-60 mt-2 px-8 md:px-0 text-center">Vehicle details</p></div>
      </div>
    </section>

    <!-- Designs — Mobile -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <p class="text-xl font-semibold leading-relaxed opacity-80 mb-4">Mobile</p>
      </div>
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div><Image src={homeModelsMobile} alt="Home ⋅ Models mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Home ⋅ models</p></div>
          <div><Image src={homeTypeMobile} alt="Home ⋅ Type mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Home ⋅ type</p></div>
          <div><Image src={resultsMobile} alt="Results mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Results</p></div>
          <div><Image src={filtersMobile} alt="Filters mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Filters</p></div>
          <div><Image src={detailsPreownedMobile} alt="Details ⋅ Pre-owned mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Vehicle details</p></div>
          <div><Image src={detailsImagesMobile} alt="Details ⋅ Images mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Vehicle images</p></div>
          <div><Image src={dealerFormMobile} alt="Dealer form mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Dealer form</p></div>
          <div><Image src={dealerPhoneMobile} alt="Dealer phone and map mobile" class="w-full rounded-[16px] mx-auto block" style="max-width:360px" /><p class="text-sm opacity-60 mt-2 text-center">Dealer ⋅ phone & Map</p></div>
        </div>
      </div>
    </section>

    <!-- Final Thoughts -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Final Thoughts</h2>
        <p class="text-lg leading-relaxed opacity-80">
          I feel we accomplished a lot for such a small team and for a short period of time. The project pushed us to balance user needs, business goals, and technical constraints while keeping the design clean and intuitive.
        </p>
      </div>
    </section>

    <!-- End CTA -->
    <section class="mb-16 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto px-8 mb-12">
        <h3 class="text-xl text-center">Thanks for reading, want to collaborate together? Contact me <a href="mailto:hi@luisisaac.com" class="underline">here</a></h3>
      </div>
    </section>

    <!-- Person using app -->
    <section class="mb-24 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={personUsingApp} alt="Person using the Kia Stock Locator" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" />
      </div>
    </section>

    <ProjectFooter nextHref="/project/rx-asx" nextTitle="RX Global At Show Experience">
      <Icon name="Compass" size={20} />
    </ProjectFooter>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Letter-by-letter fade in with color transition
  const titleEl = document.getElementById('hero-title') as HTMLElement;
  const text = titleEl.textContent?.trim() ?? '';
  titleEl.innerHTML = text
    .split(' ')
    .map(word =>
      `<span class="inline-block whitespace-nowrap">${word.split('').map(ch => `<span style="opacity:0;color:var(--muted)">${ch}</span>`).join('')}</span>`)
    .join(' ');

  gsap.set('.hero-meta', { x: -20, opacity: 0 });

  const spans = titleEl.querySelectorAll('span');
  const tl = gsap.timeline({
    onComplete: () => {
      document.querySelectorAll<HTMLElement>('.hero-meta').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
  tl.to(spans, { opacity: 1, color: 'var(--text)', duration: 0.4, stagger: 0.03, ease: 'power2.out' })
    .to('.hero-meta', { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out' })
    .fromTo('#cover-img', { y: 60, opacity: 0, filter: 'blur(20px)' }, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.8, ease: 'power3.out' });

  // Scroll reveals
  gsap.from('#opportunity', { y: 60, opacity: 0, duration: 1, delay: 0.3, ease: 'power3.out' });

  gsap.utils.toArray<HTMLElement>('.section-block:not(#opportunity)').forEach((el) => {
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
    });
  });

  // Fade in images when they finish loading (skip carousel images 2, 3 & 4)
  document.querySelectorAll<HTMLImageElement>('.section-block img:not(#bench-img-2):not(#bench-img-3):not(#bench-img-4)').forEach((img) => {
    img.style.opacity = '0';
    const show = () => gsap.to(img, { opacity: 1, duration: 1.2, ease: 'power3.out' });
    if (img.complete && img.naturalWidth > 0) show();
    else img.addEventListener('load', show, { once: true });
  });

  // Crossfade between benchmark images
  const benchImages = [
    { el: document.getElementById('bench-img-1') as HTMLElement, label: 'Porsche stock locator' },
    { el: document.getElementById('bench-img-2') as HTMLElement, label: 'Rivian stock locator' },
    { el: document.getElementById('bench-img-3') as HTMLElement, label: 'Tesla stock locator' },
    { el: document.getElementById('bench-img-4') as HTMLElement, label: 'Renault stock locator' },
  ];
  const benchCaption = document.getElementById('bench-caption') as HTMLElement;
  let benchCurrent = 0;

  setInterval(() => {
    const next = (benchCurrent + 1) % benchImages.length;
    gsap.to(benchImages[benchCurrent].el, { opacity: 0, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(benchImages[next].el, { opacity: 1, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(benchCaption, { opacity: 0, duration: 0.3, onComplete: () => {
      benchCaption.textContent = benchImages[next].label;
      gsap.to(benchCaption, { opacity: 0.5, duration: 0.3 });
    }});
    benchCurrent = next;
  }, 4000);
</script>


<script>
  document.querySelectorAll('.image-toggle').forEach((toggle) => {
    const badge = toggle.querySelector('.toggle-badge') as HTMLElement;

    toggle.addEventListener('click', (e) => {
      const before = toggle.querySelector('.toggle-before') as HTMLElement;
      const after = toggle.querySelector('.toggle-after') as HTMLElement;
      const isShowingBefore = toggle.getAttribute('data-state') === 'before';

      before.classList.toggle('hidden', isShowingBefore);
      after.classList.toggle('hidden', !isShowingBefore);
      badge.textContent = isShowingBefore ? 'After' : 'Before';
      toggle.setAttribute('data-state', isShowingBefore ? 'after' : 'before');

      const rect = (toggle as HTMLElement).getBoundingClientRect();
      badge.style.left = `${e.clientX - rect.left}px`;
      badge.style.top = `${e.clientY - rect.top}px`;
      badge.style.transform = 'translate(-50%, -50%)';
      badge.style.bottom = 'auto';
      const el = toggle as HTMLElement;
      badge.classList.remove('opacity-0');
      badge.classList.add('opacity-100');
      clearTimeout((el as any)._badgeTimer);
      (el as any)._badgeTimer = setTimeout(() => {
        badge.classList.remove('opacity-100');
        badge.classList.add('opacity-0');
      }, 3000);
    });
  });
</script>
