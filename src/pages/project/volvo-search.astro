---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import coverImg from '../../assets/Volvo-Search/cover.jpg';
import design1 from '../../assets/Volvo-Search/M.1.1 - Search.jpg';
import design2 from '../../assets/Volvo-Search/M.1.2 - Search.jpg';
import design3 from '../../assets/Volvo-Search/M.1.3 - Search.jpg';
import design4 from '../../assets/Volvo-Search/M.2.4.A - Form (Images).jpg';
import iconSearch from '../../assets/Volvo-Search/Icons/image.jpg';
import iconDocuments from '../../assets/Volvo-Search/icons/documents.jpg';
import iconEvent from '../../assets/Volvo-Search/icons/event.jpg';
import iconGeneric from '../../assets/Volvo-Search/icons/generic.jpg';
import iconJobs from '../../assets/Volvo-Search/icons/jobs.jpg';
import iconNews from '../../assets/Volvo-Search/icons/news.jpg';
import iconPressRelease from '../../assets/Volvo-Search/icons/press-release.jpg';
import iconProducts from '../../assets/Volvo-Search/icons/products.jpg';
import ProjectHero from '../../components/ProjectHero.astro';
import { Image } from 'astro:assets';
import '../../styles/global.css';
---

<Layout>
  <main>

    <Nav backHref="/" />

    <ProjectHero
      title="Volvo Search"
      meta={[
        { label: 'Role', value: 'Design Lead' },
        { label: 'Company', value: 'Volvo Trucks' },
        { label: 'Year', value: '2023' },
        { label: 'Type', value: 'Web' },
      ]}
      coverImg={coverImg}
      coverAlt="Volvo Search cover"
    />

    <!-- Opportunity -->
    <section class="mb-20 section-block" id="opportunity">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Opportunity</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">
              This project came off the back of my work on Kia's car configurator, a previous engagement that went so well Kia came back with a new challenge.
            </p>
            <p class="text-lg leading-relaxed opacity-80">
              During that period, a global chip shortage was causing significant delays in car delivery timelines, pushing customers to wait months for their configured vehicle.
            </p>
          </div>
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">
              The idea emerged: what if customers could find a similar or identical vehicle already in stock at a nearby dealer?
            </p>
            <p class="text-lg leading-relaxed opacity-80">
              Facing an increasingly competitive automotive landscape online, Kia decided to invest in improving their Stock Locator experience, helping customers find the right car now, rather than wait.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- High fidelity designs -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">High fidelity designs</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            To support consistency across a large team and many event types, I built a centralized component library — buttons, forms, icons, navigation, cards — all adhering to shared visual guidelines and interaction standards.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This reduced friction in handoffs and kept the product coherent as it scaled.
          </p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          <div><Image src={design1} alt="Search" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Volvo Insights page</p></div>
          <div><Image src={design2} alt="Search results" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Search modal, featured</p></div>
          <div><Image src={design3} alt="Search filters" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Search modal, results</p></div>
          <div><Image src={design4} alt="Form with images" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Result page</p></div>
        </div>
      </div>
    </section>

    <!-- Icons -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-4">Icons</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">In case there was no image available for a certain search result, an icon would be shown as a fallback. Each content type in the search experience is represented by a distinct icon.</p>
          <p class="text-lg leading-relaxed opacity-80">This approach helps users quickly identify and differentiate results at a glance. Also a category text label is displayed on top of each result.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { img: iconGeneric, label: 'Generic' },
            { img: iconSearch, label: 'Image' },
            { img: iconDocuments, label: 'Document' },
            { img: iconEvent, label: 'Event' },
            { img: iconJobs, label: 'Job' },
            { img: iconNews, label: 'News' },
            { img: iconPressRelease, label: 'Press Release' },
            { img: iconProducts, label: 'Product' },
          ].map(({ img, label }) => (
            <div class="flex items-center gap-4">
              <Image src={img} alt={label} class="w-16 h-16 rounded-[8px] object-cover flex-shrink-0" />
              <p class="text-lg font-medium">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const titleEl = document.getElementById('hero-title') as HTMLElement;
  const text = titleEl.textContent?.trim() ?? '';
  titleEl.style.opacity = '1';
  titleEl.innerHTML = text
    .split(' ')
    .map(word =>
      `<span class="inline-block whitespace-nowrap">${word.split('').map(ch => `<span style="opacity:0;color:var(--muted)">${ch}</span>`).join('')}</span>`)
    .join(' ');

  gsap.set('.hero-meta', { x: -20, opacity: 0 });

  const spans = titleEl.querySelectorAll('span');
  const tl = gsap.timeline();
  tl.to(spans, { opacity: 1, color: 'var(--text)', duration: 0.4, stagger: 0.03, ease: 'power2.out' })
    .to('.hero-meta', { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out' })
    .fromTo('#cover-img', { y: 60, opacity: 0, filter: 'blur(20px)' }, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.2, ease: 'power3.out' })
    .from('#opportunity', { y: 60, opacity: 0, duration: 1, ease: 'power3.out' }, '-=0.5');

  gsap.utils.toArray<HTMLElement>('.section-block:not(#opportunity)').forEach((el) => {
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
    });
  });
</script>
