---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ProjectFooter from '../../components/ProjectFooter.astro';
import Icon from '../../components/Icon.astro';
import { Image } from 'astro:assets';
import coverImg from '../../assets/RX-DS/cover.jpg';
import variablesImg from '../../assets/RX-DS/variables.jpg';
import componentButtonProperties from '../../assets/RX-DS/component-button-properties.png';
import componentButtonTheming from '../../assets/RX-DS/component-button-theming.png';
import navBarAsx from '../../assets/RX-DS/nav-bar-asx.png';
import navBarDs from '../../assets/RX-DS/nav-bar-ds.png';
import cardAsx from '../../assets/RX-DS/card-asx.jpg';
import cardRx from '../../assets/RX-DS/card-rx.jpg';
import iPadImg from '../../assets/RX-DS/iPad.jpg';
import governanceImg from '../../assets/RX-DS/governance.png';
import buttonTaxonomyImg from '../../assets/RX-DS/button-taxonomy.png';
import usabilityTestingGif from '../../assets/RX-DS/usability-testing.gif';
import asxSecondaryButton from '../../assets/RX-DS/asx-secondary-button.png';
import rxSecondaryButtons from '../../assets/RX-DS/rx-secondary-buttons.png';
---

<Layout title="RX Global Design System">
  <main>

    <Nav backHref="/" />

    <!-- Hero -->
    <section class="flex flex-col pt-24 pb-16" id="hero">
      <div class="max-w-7xl mx-auto w-full px-8">
        <h1 class="text-[clamp(2.5rem,7vw,6rem)] font-semibold leading-[1.05] tracking-tight mb-12 break-words" id="hero-title">
          RX Global Design System
        </h1>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Role</p>
            <p class="text-lg font-medium">Design Lead</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Company</p>
            <p class="text-lg font-medium">RX Global</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Year</p>
            <p class="text-lg font-medium">2025</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Type</p>
            <p class="text-lg font-medium">Design System</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cover image placeholder -->
    <section class="mb-24 overflow-hidden md:overflow-visible">
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={coverImg} alt="At Show Experience cover" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" id="cover-img" />
      </div>
    </section>

    <!-- Opportunity -->
    <section class="mb-20 section-block" id="opportunity">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Opportunity</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mx-auto">
          <p class="text-lg leading-relaxed opacity-80">
            While building the <a href="/project/rx-asx" class="underline hover:opacity-60 transition-opacity">ASX project</a>, I designed a library that quickly gained traction across teams at RX.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            Its modern approach and improved UX raised the bar for what the product could be, and became the foundation for RX’s company-wide Design System.
          </p>
        </div>
      </div>
    </section>

    <!-- Scope -->
    <section class="mb-20 section-block" id="overview">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">My role as Design Lead</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 mx-auto">
          <ul class="list-disc list-outside pl-5 mr-4 text-lg leading-relaxed opacity-80">
            <li>Process & timeline management</li>
            <li>Alignment with different company sections</li>
            <li>Adaptation of components for broader usage</li>
            <li>Creation of variables and design tokens</li>
          </ul>
          <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
            <li>Design documentation and maintenance</li>
            <li>Usability testing and iteration</li>
            <li>Governance and standardization</li>
            <li>Cross-functional collaboration with engineering, product and QA</li>
          </ul>
        </div>
      </div>
    </section>
    <!-- Variables -->
    <section class="mb-20 section-block overflow-hidden md:overflow-visible">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">
          Variables setup
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            I started by defining the design system's core variables, including color palettes, typography scales, spacing units, and iconography guidelines.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This created a shared visual language that ensured consistency across all products and platforms.
          </p>
        </div>
      </div>
      <div class="flex justify-center max-w-7xl mx-auto md:px-8">
        <Image src={variablesImg} alt="Design system variables" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-[743px] md:translate-x-0 md:left-0 md:rounded-2xl" style="min-width: 371.5px" />
      </div>
    </section>

    <!-- Components construction-->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Components construction</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mx-auto mb-4">
          <p class="text-lg leading-relaxed opacity-80">
            Each component was built to be flexible and reusable, adapting to a wide range of use cases while maintaining a cohesive design language. I worked closely with engineers to ensure components were visually refined, technically feasible, and performant.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This meant iterating based on feedback and testing until each component met the needs of both users and developers, and could be seamlessly integrated across different products. Components are built with properties for adaptability and ship with both light and dark theme support.
          </p>
        </div>
        <div class="flex flex-col items-center md:flex-row md:justify-center md:items-start gap-12 mt-8">
          <Image src={componentButtonProperties} alt="Component button properties" class="w-full max-w-[240px]" />
          <Image src={componentButtonTheming} alt="Component button theming" class="w-[240px] object-cover" style="height:308px" />
        </div>
      </div>
    </section>

    <!-- Adaptation -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">
          Component expansion
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            I adapted the ASX components for broader use, accounting for edge cases and varied states.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            I also produced documentation to ensure consistent adoption across teams.
          </p>
        </div>
        <!-- Buttons -->
        <h3 class="text-xl font-semibold mb-4">Buttons</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            The secondary button evolved to support both light and dark themes. Button text moved away from the expo's primary brand color to black and white, improving contrast and accessibility across surfaces.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            New interaction states were also introduced — including a focus state that previously didn't exist — making the component more complete and better suited to a wider range of scenarios.
          </p>
        </div>
        <div class="flex flex-col items-center md:flex-row md:justify-center md:items-start gap-8 mt-8 mb-12">
          <Image src={asxSecondaryButton} alt="ASX secondary button" class="rounded-2xl" style="width:203px;height:76px;object-fit:cover" />
          <Image src={rxSecondaryButtons} alt="RX secondary buttons" class="rounded-2xl" style="width:203px;height:176px;object-fit:cover" />
        </div>
        <h3 class="text-xl font-semibold mb-4">Navigation bar</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            Updated to Material Design 3 navigation bar, as their accessibility improved the experience and was an easier implementation for engineering.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            Also migrated to Material Design icons from the previous icon library, as it was a broader library with more icons.
          </p>
        </div>
        <!-- Exhibitor Card -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8 mb-12">
          <Image src={navBarAsx} alt="Navigation bar ASX" class="w-full rounded-2xl" />
          <Image src={navBarDs} alt="Navigation bar Design System" class="w-full rounded-2xl" />
        </div>

        <h3 class="text-xl font-semibold mb-4">Exhibitor Card</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            ASX exhibitor card was focused on a specific usage: the ASX mobile app. RX exhibitor card evolved to be used in different scenarios and edge cases, like when exhibitors have multiple stands or the stand is shared.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
           Designs were polished, and made more accessible, Like the button text wouldn’t use the theme colour, but black text. No available features were removed.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <Image src={cardAsx} alt="Exhibitor card ASX" class="w-full rounded-2xl" />
          <Image src={cardRx} alt="Exhibitor card RX" class="w-full rounded-2xl" />
        </div>
      </div>
    </section>

    <!-- Usability Testing -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Usability Testing</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <img src={usabilityTestingGif.src} alt="Usability testing" class="rounded-2xl w-full" />
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">I conducted usability testing of the design system's components in real exhibition environments, observing the usage of the updated components, in different scenarios.</p>
            <p class="text-lg leading-relaxed opacity-80 mb-4">These sessions surfaced edge cases and interaction patterns that hadn't emerged in controlled testing, giving us actionable data to refine components and improve consistency across the system.</p>
            <p class="text-lg leading-relaxed opacity-80 mb-4">Key findings included information architecture considerations in components like the cards.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Files naming and structure -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Files naming and structure</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
          <p class="text-lg leading-relaxed opacity-80">To keep the system scalable and easy to navigate, I established a clear file structure and naming convention in Figma.</p>
          <p class="text-lg leading-relaxed opacity-80">Files were split by type: Foundation Styles and Components, each with a defined status to track progress across the team.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <p class="text-xl font-semibold mb-6">Files structure</p>
            <p class="text-lg mb-3">Foundation Styles</p>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80 mb-8">
              <li>Colours</li>
              <li>Typography</li>
              <li>Spacing</li>
              <li>Layout grids</li>
              <li>Shadows (with elevation)</li>
            </ul>
            <p class="text-lg mb-3">Components</p>
            <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
              <li>Buttons</li>
              <li>Cards</li>
              <li>Navigation</li>
              <li>Chips</li>
              <li>Many others</li>
            </ul>
          </div>
          <div>
            <p class="text-xl font-semibold mb-6">Files tasks status</p>
            <ul class="text-lg leading-relaxed opacity-80 mb-6">
              <li>🗒️ To Do</li>
              <li>🟡 In Progress</li>
              <li>🟣 Ready for Review</li>
              <li>💎 Specification Added</li>
              <li>✅ Done (Signed off &amp; Spec'ed)</li>
            </ul>
            <p class="text-lg leading-relaxed opacity-80">Everything was tracked in Jira, where we also assigned tasks.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Documentation -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Documentation</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mx-auto mb-12">
          <p class="text-lg leading-relaxed opacity-80">Documentation clarifies which components are available and approved for use, helping teams onboard quickly and ensuring consistent, correct adoption across the product.</p>
          <p class="text-lg leading-relaxed opacity-80">It also improves accessibility double-checks and makes design-to-development handoffs significantly smoother. Below is the primary button taxonomy as an example.</p>
        </div>
        <div class="flex flex-col md:flex-row gap-12 items-start justify-center">
          <Image src={buttonTaxonomyImg} alt="Button taxonomy documentation" class="w-full rounded-2xl" style="max-width: 198px" />
          <ol class="list-decimal list-outside pl-5 text-lg leading-relaxed space-y-2 shrink-0">
            <li><span class="font-medium">Icon Left</span> <span class="opacity-60"> ⋅ optional</span></li>
            <li><span class="font-medium">Button Label</span></li>
            <li><span class="font-medium">Icon Right</span> <span class="opacity-60"> ⋅ optional</span></li>
          </ol>
        </div>
      </div>
    </section>

    <!-- Governance -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Governance</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mx-auto mb-8">
          <p class="text-lg leading-relaxed opacity-80">I established a governance process to ensure the design system could scale and be adopted consistently across the company.</p>
          <p class="text-lg leading-relaxed opacity-80">This defined how components are proposed, reviewed, and approved, giving teams a clear path to contribute while maintaining quality and coherence across products.</p>
        </div>
      </div>
      <div class="overflow-x-auto mt-16 flex lg:justify-center lg:px-8">
        <Image src={governanceImg} alt="Governance" class="w-[1200px] min-w-[1200px] object-cover" />
      </div>
    </section>

    <!-- Final Thoughts -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Final Thoughts</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
          <div>
            <p class="text-xl font-semibold mb-2">Align early and often</p>
            <p class="text-lg leading-relaxed opacity-60">Early alignment across design, engineering, and product is crucial. It sets shared expectations, reduces rework, and keeps the system grounded in real needs.</p>
          </div>
          <div>
            <p class="text-xl font-semibold mb-2">Prioritize adoption and stay open to iteration</p>
            <p class="text-lg leading-relaxed opacity-60">They're only valuable when used, so support adoption with clear documentation, practical examples, and internal advocacy. Keep evolving components as needs, feedback, and constraints change.</p>
          </div>
          <div>
            <p class="text-xl font-semibold mb-2">Support creativity, don't suppress it</p>
            <p class="text-lg leading-relaxed opacity-60">A good system provides guidance, not rigid rules. It should empower designers to solve problems creatively within a consistent framework.</p>
          </div>
          <div>
            <p class="text-xl font-semibold mb-2">Establish governance early</p>
            <p class="text-lg leading-relaxed opacity-60">Without defined ownership and processes, systems stall. Clear governance ensures updates are intentional, feedback is heard, and the system scales sustainably.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cover image end -->
    <section class="mb-16 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto px-8 mb-12">
        <h3 class="text-xl text-center">Thanks for reading, want to collaborate together? Contact me <a href="mailto:isaacvigil@gmail.com" class="underline hover:opacity-60 transition-opacity">here</a></h3>
      </div>
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={iPadImg} alt="At Show Experience" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" />
      </div>
    </section>

    <ProjectFooter nextHref="/project/kia-stock-locator" nextTitle="Kia Stock Locator">
      <Icon name="Car" size={20} />
    </ProjectFooter>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Letter-by-letter fade in with color transition
  const titleEl = document.getElementById('hero-title') as HTMLElement;
  const text = titleEl.textContent?.trim() ?? '';
  titleEl.innerHTML = text
    .split(' ')
    .map(word =>
      `<span class="inline-block whitespace-nowrap">${word.split('').map(ch => `<span style="opacity:0;color:var(--muted)">${ch}</span>`).join('')}</span>`)
    .join(' ');

  gsap.set('.hero-meta', { x: -20, opacity: 0 });

  const spans = titleEl.querySelectorAll('span');
  const tl = gsap.timeline({
    onComplete: () => {
      document.querySelectorAll<HTMLElement>('.hero-meta').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
  tl.to(spans, { opacity: 1, color: 'var(--text)', duration: 0.4, stagger: 0.03, ease: 'power2.out' })
    .to('.hero-meta', { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out' })
    .fromTo('#cover-img', { y: 60, opacity: 0, filter: 'blur(20px)' }, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.8, ease: 'power3.out' });

  // Scroll reveals
  // Opportunity loads with the page
  gsap.from('#opportunity', { y: 60, opacity: 0, duration: 1, delay: 0.3, ease: 'power3.out' });

  gsap.utils.toArray<HTMLElement>('.section-block:not(#opportunity)').forEach((el) => {
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
    });
  });

  // Fade in images when they finish loading (works with lazy-loaded images)
  document.querySelectorAll<HTMLImageElement>('.section-block img:not(#event-img-1):not(#event-img-2)').forEach((img) => {
    img.style.opacity = '0';
    const show = () => gsap.to(img, { opacity: 1, duration: 1.2, ease: 'power3.out' });
    if (img.complete && img.naturalWidth > 0) show();
    else img.addEventListener('load', show, { once: true });
  });

  // Crossfade between event images
  const eventImages = [
    { el: document.getElementById('event-img-1') as HTMLElement, label: 'FIBO' },
    { el: document.getElementById('event-img-2') as HTMLElement, label: 'WTM London' },
    { el: document.getElementById('event-img-3') as HTMLElement, label: 'World Hydrogen Summit' },
  ];
  const caption = document.getElementById('event-caption') as HTMLElement;
  let eventCurrent = 0;

  setInterval(() => {
    const next = (eventCurrent + 1) % eventImages.length;
    gsap.to(eventImages[eventCurrent].el, { opacity: 0, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(eventImages[next].el, { opacity: 1, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(caption, { opacity: 0, duration: 0.3, onComplete: () => {
      caption.textContent = eventImages[next].label;
      gsap.to(caption, { opacity: 0.5, duration: 0.3 });
    }});
    eventCurrent = next;
  }, 4000);
</script>
