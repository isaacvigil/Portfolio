---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { Image } from 'astro:assets';
import mapFibo1 from '../../assets/RX-ASX/map-fibo-1.jpeg';
import mapFibo2 from '../../assets/RX-ASX/map-fibo-2.jpeg';
import mapFibo3 from '../../assets/RX-ASX/map-fibo-3.jpeg';
import printedList from '../../assets/RX-ASX/printed-list.jpeg';
import coverImg from '../../assets/RX-ASX/cover.jpg';
import usabilityTestingGif from '../../assets/RX-ASX/usability-testing.gif';
import componentsImg from '../../assets/RX-ASX/components.png';
import design1 from '../../assets/RX-ASX/1.1-Sponsor.jpg';
import design2 from '../../assets/RX-ASX/1.2-My-Bag-Schedule.jpg';
import design3 from '../../assets/RX-ASX/2.1-Map.jpg';
import design4 from '../../assets/RX-ASX/3.3-Colleqt-QR-Scan.jpg';
import design5 from '../../assets/RX-ASX/3.5-Colleqt-My-Badge.jpg';
import design6 from '../../assets/RX-ASX/4.1-Whats-On-Programme.jpg';
import design7 from '../../assets/RX-ASX/4.2-Exhibitors.jpg';
import design8 from '../../assets/RX-ASX/4.3-Exhibitors-Products.jpg';
import design9 from '../../assets/RX-ASX/8.2-Product.jpg';
import design10 from '../../assets/RX-ASX/8.3-Session.jpg';
import design11 from '../../assets/RX-ASX/8.4-Exhibitor-Profile.jpg';
import design12 from '../../assets/RX-ASX/9.4-Speaker-Profile.jpg';
import mapDirections from '../../assets/RX-ASX/map-directions.png';
import placeholderHandsTable from '../../assets/RX-ASX/placeholder-hands-table.jpg';
import badgeAnimation from '../../assets/RX-ASX/badge-animation.mov';
import videoAnimations from '../../assets/RX-ASX/video-animations.mp4';
import videoAnimationsPlaceholder from '../../assets/RX-ASX/video-animations-placeholder.png';
import expoFibo from '../../assets/RX-ASX/expo-fibo.jpg';
import expoWtmLondon from '../../assets/RX-ASX/expo-wtm-london.jpg';
import expoWorldHydrogen from '../../assets/RX-ASX/expo-world-hydrogen.jpg';
import ProjectFooter from '../../components/ProjectFooter.astro';
import Icon from '../../components/Icon.astro';
import ComponentsImage from '../../components/ComponentsImage.astro';
---

<Layout>
  <main>

    <Nav backHref="/" />

    <!-- Hero -->
    <section class="flex flex-col pt-24 pb-16" id="hero">
      <div class="max-w-7xl mx-auto w-full px-8">
        <h1 class="text-[clamp(2.5rem,7vw,6rem)] font-semibold leading-[1.05] tracking-tight mb-12 break-words" id="hero-title" style="opacity:0">
          RX Global At Show Experience
        </h1>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Role</p>
            <p class="text-lg font-medium">Design Lead</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Company</p>
            <p class="text-lg font-medium">RX Global</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Year</p>
            <p class="text-lg font-medium">2024</p>
          </div>
          <div class="hero-meta" style="opacity:0">
            <p class="text-base opacity-60 mb-2">Type</p>
            <p class="text-lg font-medium">Mobile App</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cover image placeholder -->
    <section class="mb-24 overflow-hidden md:overflow-visible">
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={coverImg} alt="At Show Experience cover" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" id="cover-img" style="opacity:0" />
      </div>
    </section>

    <!-- Opportunity -->
    <section class="mb-20 section-block" id="opportunity">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Opportunity</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <p class="text-lg leading-relaxed opacity-80">
            RX, the world's second-largest exhibition organizer, part of RELX (formerly Reed Elsevier), operates over 350 events across 25 countries, including well known events like: Comic Con, PGA Show, and London Book Fair.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            Despite its strong presence across diverse industries, and continents, no companion app existed to enhance the attendee experience at these events.
          </p>
        </div>
      </div>
    </section>

    <!-- Scope -->
    <section class="mb-20 section-block" id="overview">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">My role as Design Lead</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 mx-auto">
          <ul class="list-disc list-outside pl-5 mr-4 text-lg leading-relaxed opacity-80">
            <li>Design & research strategy</li>
            <li>Process & timeline management</li>
            <li>Designs, prototypes, components creation</li>
            <li>User Research</li>
          </ul>
          <ul class="list-disc list-outside pl-5 text-lg leading-relaxed opacity-80">
            <li>Design alignment across the company</li>
            <li>Stakeholder alignment between:
              <ul class="list-disc list-outside pl-5 ml-1 mt-1">
                <li>HQ</li>
                <li>Country managers</li>
                <li>Expo organizers</li>
              </ul>
            </li>
            <li>Cross-functional collaboration with:
              <ul class="list-disc list-outside pl-5 ml-1 mt-1">
                <li>Product</li>
                <li>Engineering</li>
                <li>QA</li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Expo Images -->
    <section class="mb-24 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto md:px-8">
        <div class="relative" id="event-img-container">
          <Image src={expoFibo} alt="FIBO" id="event-img-1" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" />
          <Image src={expoWtmLondon} alt="WTM London" id="event-img-2" class="absolute inset-0 left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover opacity-0" />
          <Image src={expoWorldHydrogen} alt="World Hydrogen" id="event-img-3" class="absolute inset-0 left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover opacity-0" />
        </div>
        <p class="text-sm opacity-50 mt-2 px-8 md:px-0 text-center" id="event-caption">FIBO</p>
      </div>
    </section>

    <!-- User research -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">
          Discovery
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            I conducted user interviews at FIBO in Cologne, and in-cosmetics in Paris, both with attendees and exhibitors, gathering insights that directly informed the app's design, ensuring it addressed real user needs and pain points effectively.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            On-site observation was also key. Research conducted revealed a clear pattern: visitors struggled with wayfinding, resorted to photographing printed maps, and had no centralized way to manage schedules, discover exhibitors, or engage with sessions in real time.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div><Image src={mapFibo1} alt="FIBO map 1" class="w-full rounded-[8px] object-cover" /><p class="text-sm opacity-50 mt-2 text-center">Attendees taking pics of the map</p></div>
          <div><Image src={mapFibo2} alt="FIBO map 2" class="w-full rounded-[8px] object-cover" /><p class="text-sm opacity-50 mt-2 text-center">Attendees looking at the map</p></div>
          <div><Image src={mapFibo3} alt="FIBO map 3" class="w-full rounded-[8px] object-cover" /><p class="text-sm opacity-50 mt-2 text-center">FIBO's hall map</p></div>
          <div><Image src={printedList} alt="Printed exhibitor list" class="w-full rounded-[8px] object-cover" /><p class="text-sm opacity-50 mt-2 text-center">Printed map and exhibitors list</p></div>
        </div>
      </div>
    </section>

    <!-- Components library-->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Components library</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <p class="text-lg leading-relaxed opacity-80">
            To support consistency across a large team and many event types, I built a centralized component library: buttons, forms, icons, navigation, cards... All adhering to shared visual guidelines and interaction standards.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This reduced friction in handoffs and kept the product coherent as it scaled across different features, events and teams.
          </p>
        </div>
      </div>
      <div class="mt-8">
        <ComponentsImage src={componentsImg} alt="Component library" />
      </div>
    </section>

    <!-- Designs -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">High fidelity designs</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            To support consistency across a large team and many event types, I built a centralized component library — buttons, forms, icons, navigation, cards — all adhering to shared visual guidelines and interaction standards.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This reduced friction in handoffs and kept the product coherent as it scaled.
          </p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-8">
          <div><Image src={design1} alt="Splash screen with sponsor" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Splash screen with sponsor</p></div>
          <div><Image src={design2} alt="Schedule" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Schedule</p></div>
          <div><Image src={design3} alt="Map" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Map</p></div>
          <div><Image src={design4} alt="QR scan" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">QR scan</p></div>
          <div><Image src={design5} alt="User's badge" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">User's badge</p></div>
          <div><Image src={design6} alt="Programme" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Programme</p></div>
          <div><Image src={design7} alt="Exhibitors" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Exhibitors</p></div>
          <div><Image src={design8} alt="Products" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Products</p></div>
          <div><Image src={design9} alt="Product details" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Product details</p></div>
          <div><Image src={design10} alt="Session details" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Session details</p></div>
          <div><Image src={design11} alt="Exhibitor profile" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Exhibitor profile</p></div>
          <div><Image src={design12} alt="Speaker profile" class="w-full rounded-[24px] max-w-[390px] mx-auto" /><p class="text-sm opacity-50 mt-2 text-center">Speaker profile</p></div>
        </div>
      </div>
    </section>

    <!-- Usability Testing -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Usability Testing</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <img src={usabilityTestingGif.src} alt="Usability testing" class="rounded-2xl w-full" />
          <div>
            <p class="text-lg leading-relaxed opacity-80 mb-4">I conducted usability testing of the prototype at FIBO in Cologne and in-cosmetics in Paris, amongst both attendees and exhibitors.</p>
            <p class="text-lg leading-relaxed opacity-80 mb-4">These efforts provided valuable insights into how users interacted with the prototype, highlighting pain points and areas for improvement, helping us identify opportunities to enhance user engagement and satisfaction at future exhibitions.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Animations -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Animations</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <p class="text-lg leading-relaxed opacity-80">
            The app incorporates multiple animations to enhance the user experience, adding a dynamic and polished feel to interactions. For example, animations were introduced when scanning a QR code and when opening the digital badge.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            These subtle yet engaging visual elements not only make the app more intuitive but also contribute to a seamless and enjoyable user journey.
          </p>
        </div>
        <video src={videoAnimations} poster={videoAnimationsPlaceholder.src} autoplay loop muted playsinline class="mt-8 rounded-[24px] w-full max-w-[388px] mx-auto block" style="clip-path: inset(0 2px 0 0 round 24px)" />
      </div>
    </section>

    <!-- Final Thoughts -->
    <section class="mb-20 section-block">
      <div class="max-w-5xl mx-auto px-8">
        <h2 class="text-section-heading mb-6">Final Thoughts</h2>
        <p class="text-xl font-semibold leading-relaxed opacity-80">Alignment</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-2">
          <p class="text-lg leading-relaxed opacity-80">
            Aligning a wide range of stakeholders — HQ, country managers, and expo organizers — required constant communication and clear expectation setting.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            This required more time and effort than the design work itself.
          </p>
        </div>
        <p class="text-xl font-semibold leading-relaxed opacity-80 mt-8">Clear Scope</p>
        <p class="text-lg leading-relaxed opacity-80 mt-2">
          To keep the project on track, I had to specify:
        </p>
        <ul class="list-disc list-outside pl-5 mt-4 text-lg leading-relaxed opacity-80">
          <li>Features</li>
          <li>Releases</li>
          <li>Timeline</li>
        </ul>
        <p class="text-xl font-semibold leading-relaxed opacity-80 mt-8">Constraints</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-2">
          <p class="text-lg leading-relaxed opacity-80">
            Connectivity at live events was an unexpected constraint. Without reliable GPS, we couldn't pinpoint user location on the map.
          </p>
          <p class="text-lg leading-relaxed opacity-80">
            I designed having an input to ask the user their current location, to set a starting point, or take a photo of the surrounding area:
          </p>
        </div>
      </div>
      <div class="flex justify-center mt-8 px-8">
        <Image src={mapDirections} alt="Map directions" class="rounded-2xl max-w-[328px] w-full" />
      </div>
    </section>

    <!-- Cover image end -->
    <section class="mb-16 overflow-hidden md:overflow-visible section-block">
      <div class="max-w-7xl mx-auto px-8 mb-12">
        <h3 class="text-xl text-center">Thanks for reading, want to collaborate together? Contact me <a href="mailto:hi@luisisaac.com" class="underline">here</a></h3>
      </div>
      <div class="max-w-7xl mx-auto md:px-8">
        <Image src={placeholderHandsTable} alt="At Show Experience" class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" />
      </div>
    </section>

    <ProjectFooter nextHref="/project/rx-ds" nextTitle="RX Global Design System">
      <Icon name="Box" size={20} />
    </ProjectFooter>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Letter-by-letter fade in with color transition
  const titleEl = document.getElementById('hero-title') as HTMLElement;
  const text = titleEl.textContent?.trim() ?? '';
  titleEl.style.opacity = '1';
  titleEl.innerHTML = text
    .split(' ')
    .map(word =>
      `<span class="inline-block whitespace-nowrap">${word.split('').map(ch => `<span style="opacity:0;color:var(--muted)">${ch}</span>`).join('')}</span>`)
    .join(' ');

  gsap.set('.hero-meta', { x: -20, opacity: 0 });

  const spans = titleEl.querySelectorAll('span');
  const tl = gsap.timeline({
    onComplete: () => {
      document.querySelectorAll<HTMLElement>('.hero-meta').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
  tl.to(spans, { opacity: 1, color: 'var(--text)', duration: 0.4, stagger: 0.03, ease: 'power2.out' })
    .to('.hero-meta', { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out' })
    .fromTo('#cover-img', { y: 60, opacity: 0, filter: 'blur(20px)' }, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.8, ease: 'power3.out' });

  // Scroll reveals
  // Opportunity loads with the page
  gsap.from('#opportunity', { y: 60, opacity: 0, duration: 1, delay: 0.3, ease: 'power3.out' });

  gsap.utils.toArray<HTMLElement>('.section-block:not(#opportunity)').forEach((el) => {
    gsap.from(el, {
      y: 60,
      opacity: 0,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
    });
  });

  // Fade in images when they finish loading (works with lazy-loaded images)
  document.querySelectorAll<HTMLImageElement>('.section-block img:not(#event-img-1):not(#event-img-2)').forEach((img) => {
    img.style.opacity = '0';
    const show = () => gsap.to(img, { opacity: 1, duration: 1.2, ease: 'power3.out' });
    if (img.complete && img.naturalWidth > 0) show();
    else img.addEventListener('load', show, { once: true });
  });

  // Crossfade between event images
  const eventImages = [
    { el: document.getElementById('event-img-1') as HTMLElement, label: 'FIBO' },
    { el: document.getElementById('event-img-2') as HTMLElement, label: 'WTM London' },
    { el: document.getElementById('event-img-3') as HTMLElement, label: 'World Hydrogen Summit' },
  ];
  const caption = document.getElementById('event-caption') as HTMLElement;
  let eventCurrent = 0;

  setInterval(() => {
    const next = (eventCurrent + 1) % eventImages.length;
    gsap.to(eventImages[eventCurrent].el, { opacity: 0, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(eventImages[next].el, { opacity: 1, duration: 0.8, ease: 'power2.inOut' });
    gsap.to(caption, { opacity: 0, duration: 0.3, onComplete: () => {
      caption.textContent = eventImages[next].label;
      gsap.to(caption, { opacity: 0.5, duration: 0.3 });
    }});
    eventCurrent = next;
  }, 4000);
</script>
