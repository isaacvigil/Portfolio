---
import '../styles/global.css'

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Isaac Vigil — Design Portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Isaac Vigil</title>
  </head>
  <body class="font-sans antialiased">
    <slot />
    <footer class="py-8 px-8">
      <div class="max-w-7xl mx-auto px-8 flex flex-col-reverse md:flex-row md:items-center md:justify-between gap-4 text-sm opacity-80 items-center md:items-stretch">
        <p class="text-center md:text-left">2026 © Luis Isaac</p>
        <div class="flex items-center gap-6 justify-center md:justify-end">
          <a href="mailto:isaacvigil@gmail.com" class="hover:opacity-70 transition-opacity">Contact</a>
          <a href="https://www.linkedin.com/in/isaacvigil" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">LinkedIn</a>
          <a href="https://www.isaacvigil.com/wp-content/uploads/Isaac-Vigil-Resume.pdf" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">Resume</a>
          <a href="https://tracklight.app" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">TrackLight</a>
        </div>
      </div>
    </footer>
    <script is:inline>
      // Apply saved theme before paint to avoid flash
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </body>
</html>
