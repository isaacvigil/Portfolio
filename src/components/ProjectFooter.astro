---
interface Props {
  nextHref: string;
  nextTitle: string;
}

const { nextHref, nextTitle } = Astro.props;
---

<section class="py-32">
  <div class="max-w-7xl mx-auto px-8 flex items-center justify-between">
    <p class="text-sm opacity-40">Next project</p>
    <a href={nextHref} class="group flex items-center gap-3 text-lg font-semibold hover:opacity-60 transition-opacity">
      {nextTitle}
      <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
    </a>
  </div>
</section>
