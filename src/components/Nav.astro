---
interface Props {
  backHref?: string;
}

const { backHref = '/' } = Astro.props;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 px-8 py-3 transition-all duration-300 border-b border-transparent">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a
      href="/"
      class="opacity-60 hover:opacity-100 transition-all duration-200 w-10 h-10 flex items-center justify-center rounded-full border border-current/20 hover:border-current/40 bg-[var(--bg)]"
      aria-label="Home"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
        <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      </svg>
    </a>
    <div class="flex items-center gap-6">
      <button
        id="theme-toggle"
        class="opacity-60 hover:opacity-100 transition-all duration-200 w-10 h-10 flex items-center justify-center rounded-full border border-current/20 hover:border-current/40 bg-[var(--bg)]"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 3v1"/><path d="M12 20v1"/>
          <path d="M3 12h1"/><path d="M20 12h1"/>
          <path d="m18.364 5.636-.707.707"/><path d="m6.343 17.657-.707.707"/>
          <path d="m5.636 5.636.707.707"/><path d="m17.657 17.657.707.707"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="">
          <path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function updateIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    iconSun?.classList.toggle('hidden', !isDark);
    iconMoon?.classList.toggle('hidden', isDark);
  }
  updateIcon();

  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    updateIcon();
  });

const nav = document.getElementById('main-nav');
  function updateNav() {
    if (window.scrollY > 10) {
      nav?.classList.add('bg-[var(--bg)]/80', 'backdrop-blur-md', 'border-[var(--dot)]');
      nav?.classList.remove('border-transparent');
    } else {
      nav?.classList.remove('bg-[var(--bg)]/80', 'backdrop-blur-md', 'border-[var(--dot)]');
      nav?.classList.add('border-transparent');
    }
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });
</script>
