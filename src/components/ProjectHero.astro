---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  meta: MetaItem[];
  coverImg: ImageMetadata;
  coverAlt: string;
}

const { title, meta, coverImg, coverAlt } = Astro.props;
---

<!-- Hero -->
<section class="flex flex-col pt-24 pb-16" id="hero">
  <div class="max-w-7xl mx-auto w-full px-8">
    <h1 class="text-[clamp(2.5rem,7vw,6rem)] font-semibold leading-[1.05] tracking-tight mb-12 break-words" id="hero-title" style="opacity:0">
      {title}
    </h1>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {meta.map(({ label, value }) => (
        <div class="hero-meta" style="opacity:0">
          <p class="text-base opacity-60 mb-2">{label}</p>
          <p class="text-lg font-medium">{value}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Cover image -->
<section class="mb-24 overflow-hidden md:overflow-visible">
  <div class="max-w-7xl mx-auto md:px-8">
    <Image src={coverImg} alt={coverAlt} class="relative left-1/2 -translate-x-1/2 w-[810px] max-w-none md:w-full md:max-w-full md:translate-x-0 md:left-0 md:rounded-2xl object-cover" id="cover-img" style="opacity:0" />
  </div>
</section>
